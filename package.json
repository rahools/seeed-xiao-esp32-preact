{
  "name": "webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "upload-data": "pnpm run build && pio run --target uploadfs --environment seeed_xiao_esp32c6",
    "upload-main-and-monitor": "pio run --target upload --target monitor",
    "upload-main": "pio run --target upload",
    "dev:hardware": "pnpm run upload-data && pnpm run upload-main-and-monitor",
    "format:cpp": "find src -name '*.cpp' -o -name '*.h' | xargs clang-format -i",
    "format:check:cpp": "find src -name '*.cpp' -o -name '*.h' | xargs clang-format --dry-run --Werror",
    "format": "biome format --write . && pnpm run format:cpp",
    "format:check": "biome format . && pnpm run format:check:cpp"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-router": "^1.139.12",
    "@tanstack/react-router-devtools": "^1.139.14",
    "@tanstack/router": "0.0.1-beta.53",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "preact": "^10.27.0",
    "preact-slots": "^1.0.0",
    "react-hook-form": "^7.67.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/router-plugin": "^1.139.14",
    "@types/node": "^24.3.1",
    "tw-animate-css": "^1.3.8",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
